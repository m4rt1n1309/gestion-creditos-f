{
  "name": "gestion-creditos-f",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:gestion-creditos-f": "node dist/gestion-creditos-f/server/server.mjs",
    "e2e": "cypress open",
    "e2e:run": "cypress run",
    "e2e:report:txt": "cypress run 2>&1 | tee cypress-report.txt",
    "e2e:report": "mochawesome-merge cypress/reports/mocha/*.json -o cypress/reports/report.json && marge cypress/reports/report.json --reportDir cypress/reports --inline",
    "e2e:clean": "node -e \"const fs=require('fs');const d='cypress/reports/mocha';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>fs.unlinkSync(d+'/'+f));\"",
    "e2e:all": "npm run e2e:clean && cypress run && npm run e2e:report"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/ssr": "^18.2.21",
    "chart.js": "^4.5.1",
    "date-fns": "^3.6.0",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "primeicons": "^6.0.1",
    "primeng": "^17.18.15",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "autoprefixer": "^10.5.0",
    "cypress": "^13.17.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.5.2"
  }
}
